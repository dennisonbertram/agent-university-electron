{
  "name": "l-capstone-pulse",
  "version": "1.0.0",
  "private": true,
  "productName": "Pulse",
  "description": "Capstone — Pulse: a no-dock macOS menu-bar focus + encrypted-journal app. Combines L1-L5 (skeleton, secure IPC, storage, deep macOS surfaces, packaging+updater+crashReporter) with SQLite (better-sqlite3) + safeStorage encryption + Touch ID gating.",
  "main": "dist/main.js",
  "scripts": {
    "clean": "rm -rf dist out",
    "build:main": "tsc -p tsconfig.json",
    "build:preload": "node scripts/build-preload.mjs",
    "build:renderer": "node scripts/copy-renderer.mjs",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "patch:better-sqlite3": "node scripts/patches/better-sqlite3-v8-tag.mjs",
    "postinstall": "npm run patch:better-sqlite3",
    "rebuild:electron": "npm run patch:better-sqlite3 && electron-rebuild",
    "rebuild:node": "npm rebuild better-sqlite3 --build-from-source",
    "prestart": "npm run build && npm run rebuild:electron",
    "start": "electron-forge start",
    "prepackage": "npm run build && npm run rebuild:electron",
    "package": "electron-forge package",
    "premake": "npm run build && npm run rebuild:electron",
    "make": "electron-forge make",
    "make:universal": "electron-forge make --arch=universal",
    "pretest": "npm run rebuild:node",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "pretest:e2e": "npm run build && npm run rebuild:electron"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.1",
    "@electron-forge/maker-dmg": "7.11.1",
    "@electron-forge/maker-zip": "7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "7.11.1",
    "@electron-forge/plugin-fuses": "7.11.1",
    "@electron-forge/shared-types": "7.11.1",
    "@electron/fuses": "1.8.0",
    "@electron/notarize": "3.1.1",
    "@electron/rebuild": "4.0.1",
    "@electron/universal": "3.0.0",
    "@playwright/test": "1.60.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "22.10.0",
    "electron": "42.1.0",
    "esbuild": "0.24.0",
    "plist": "3.1.0",
    "typescript": "5.6.3",
    "vitest": "4.1.6",
    "yaml": "2.6.1"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "electron-log": "5.2.0",
    "electron-updater": "6.8.3"
  }
}
