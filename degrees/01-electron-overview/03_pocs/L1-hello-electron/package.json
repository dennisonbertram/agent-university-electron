{
  "name": "l1-hello-electron",
  "version": "0.1.0",
  "private": true,
  "description": "POC L1 — Hello Electron: smoke-test main + preload + renderer + structured logger.",
  "main": "dist/main.js",
  "scripts": {
    "clean": "rm -rf dist .vite",
    "build": "tsc -p tsconfig.json && node scripts/copy-renderer.mjs",
    "prestart": "npm run build",
    "start": "electron .",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "pretest:e2e": "npm run build"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "22.10.0",
    "electron": "42.1.0",
    "typescript": "5.6.3",
    "vitest": "4.1.6"
  }
}
